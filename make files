#!/bin/bash
# Run this from: /data/Desktop/Piper/UMGC_Data/Cristol_Project_001

BASE_DIR="/data/Desktop/Piper/UMGC_Data/Cristol_Project_001"
OUT_DIR="${BASE_DIR}/grouped_samples"

mkdir -p "$OUT_DIR"/{eggshell_mockingbird,eggshell_cardinal,nestmaterial_mockingbird,nestmaterial_cardinal,nestswab_mockingbird,nestswab_cardinal,controls}

# Find all real fastq.gz files, excluding test_subset dir and any 200k subsampled files
find "$BASE_DIR" -type f -name "*.fastq.gz" \
  ! -path "*/test_subset/*" \
  ! -name "*_200k.fastq.gz" | while read -r filepath; do

  fname=$(basename "$filepath")

  case "$fname" in
    *-e-mb*|*-e-mb-*)   dest="eggshell_mockingbird" ;;
    *-e-nc*|*-e-nc-*)   dest="eggshell_cardinal" ;;
    *-nm-mb*)           dest="nestmaterial_mockingbird" ;;
    *-nm-nc*)           dest="nestmaterial_cardinal" ;;
    *-ns-mb*|*-ns-mb-*) dest="nestswab_mockingbird" ;;
    *-ns-nc*)           dest="nestswab_cardinal" ;;
    blank-*|SynMock*)   dest="controls" ;;
    *)                  dest="unmatched" ;;
  esac

  mkdir -p "$OUT_DIR/$dest"
  ln -sf "$filepath" "$OUT_DIR/$dest/$fname"
done

echo "Done. Group counts:"
for d in "$OUT_DIR"/*/; do
  echo "$(basename "$d"): $(ls "$d" | wc -l) files"
done
