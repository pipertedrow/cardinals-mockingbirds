#!/bin/bash
# Run this from: /data/Desktop/Piper/UMGC_Data/Cristol_Project_001

BASE_DIR="/data/Desktop/Piper/UMGC_Data/Cristol_Project_001"
OUT_DIR="${BASE_DIR}/grouped_samples"

mkdir -p "$OUT_DIR"/{eggshell_mockingbird,eggshell_cardinal,nestmaterial_mockingbird,nestmaterial_cardinal,nestswab_mockingbird,nestswab_cardinal,controls}

# Find all real fastq.gz files, excluding test_subset dir and any 200k subsampled files
find "$BASE_DIR" -type f -name "*.fastq.gz" \
  ! -path "*/test_subset/*" \
  ! -name "*_200k.fastq.gz" | while read -r filepath; do

  fname=$(basename "$filepath")

  case "$fname" in
    *-e-mb*|*-e-mb-*)   dest="eggshell_mockingbird" ;;
    *-e-nc*|*-e-nc-*)   dest="eggshell_cardinal" ;;
    *-nm-mb*)           dest="nestmaterial_mockingbird" ;;
    *-nm-nc*)           dest="nestmaterial_cardinal" ;;
    *-ns-mb*|*-ns-mb-*) dest="nestswab_mockingbird" ;;
    *-ns-nc*)           dest="nestswab_cardinal" ;;
    blank-*|SynMock*)   dest="controls" ;;
    *)                  dest="unmatched" ;;
  esac

  mkdir -p "$OUT_DIR/$dest"
  ln -sf "$filepath" "$OUT_DIR/$dest/$fname"
done

echo "Done. Group counts:"
for d in "$OUT_DIR"/*/; do
  echo "$(basename "$d"): $(ls "$d" | wc -l) files"
done

now make manifest files --> this step is before demultiplex to then normalize sequence lengths  

for group in "$OUT_DIR"/*/; do
  group_name=$(basename "$group")
  [ "$group_name" == "controls" ] && continue  # skip if you don't want to import controls separately

  cd "$group"
  echo -e "sample-id\tforward-absolute-filepath\treverse-absolute-filepath" > manifest.tsv

  for f in *_R1_001.fastq.gz; do
    sample=$(echo "$f" | sed 's/_R1_.*//')
    r2=$(echo "$f" | sed 's/_R1_/_R2_/')
    echo -e "$sample\t$PWD/$f\t$PWD/$r2" >> manifest.tsv
  done

  cd "$OUT_DIR"
done

now demux

qiime tools import \
  --type 'SampleData[PairedEndSequencesWithQuality]' \
  --input-path /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/manifest.tsv \
  --output-path /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_demux.qza \
  --input-format PairedEndFastqManifestPhred33V2

demux visualize 

qiime demux summarize \
  --i-data /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_demux.qza \
  --o-visualization /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_demux.qzv

qiime dada2 denoise-paired \
  --i-demultiplexed-seqs /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_demux.qza \
  --p-trim-left-f 0 \
  --p-trim-left-r 0 \
  --p-trunc-len-f 180 \
  --p-trunc-len-r 180 \
  --p-n-threads 2 \
  --o-representative-sequences /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_rep-seqs.qza \
  --o-table /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_table.qza \
  --o-denoising-stats /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_denoising-stats.qza \
  --o-base-transition-stats /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_base-transition-stats.qza \
  --verbose

qiime metadata tabulate \
  --m-input-file /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_base-transition-stats.qza \
  --o-visualization /data/Desktop/Piper/UMGC_Data/Cristol_Project_001/grouped_samples/eggshell_cardinal/eggshell_cardinal_base-transition-stats.qzv


